# Expo client (web/Android/iOS)
#
# Optional development/self-hosted connector. Leave both blank for local-only
# operation. Provider credentials belong in app-private Settings, not this file.
EXPO_PUBLIC_LIFEOS_SERVER_URL=
EXPO_PUBLIC_LIFEOS_SERVER_TOKEN=

