    "phase8:check:release-readiness": "node scripts/quality/check-release-readiness.mjs",
    "phase9:check:native-visual-matrix": "./scripts/quality/check-native-visual-matrix.sh",
    "phase9:check:responsive-visual-matrix": "node scripts/quality/check-responsive-visual-matrix.mjs",
    "phase9:check:performance-budget": "node scripts/quality/check-performance-budget.mjs",
