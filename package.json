    "phase4:check:mcp": "npm run phase4:check:mcp-tool-contract && npm run phase4:check:mcp-workflow-replay && npm run phase4:check:mcp-workflow-replay:http",
    "phase3:check:chat-undo": "./server/node_modules/.bin/tsx --tsconfig tsconfig.json scripts/quality/check-phase3-chat-undo.ts",
    "phase3:check:chat-send": "./server/node_modules/.bin/tsx --tsconfig tsconfig.json scripts/quality/check-phase3-chat-send.ts",
    "check:chat-product-language": "./server/node_modules/.bin/tsx --tsconfig tsconfig.json scripts/quality/check-chat-product-language.ts",
    "phase3:check:chat-rollback-idempotency": "./server/node_modules/.bin/tsx --tsconfig tsconfig.json scripts/quality/check-phase3-chat-rollback-idempotency.ts",
    "phase7:check:chat-client-cross-surface": "./server/node_modules/.bin/tsx --tsconfig tsconfig.json scripts/quality/check-phase7-chat-client-cross-surface.ts",
    "phase8:check:health-connect": "./scripts/quality/check-health-connect-android.sh",
    "phase8:check:android-release-artifacts": "./scripts/quality/check-android-release-artifacts.sh",
