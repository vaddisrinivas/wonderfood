    "check:migrations": "vitest run tests/db/migrations.test.ts",
    "check:control-plane-c0": "vitest run tests/db/migrations.test.ts",
    "check:control-plane-c1": "vitest run tests/config/fetchers.test.ts",
    "check:control-plane-c2": "vitest run tests/config/runtime.test.ts",
    "check:control-plane-c3": "vitest run tests/config/sync.test.ts",
