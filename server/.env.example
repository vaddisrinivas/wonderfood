# LifeOS server runtime. Inject secrets through the private agent environment.
PORT=8790
LIFEOS_SERVER_HOST=0.0.0.0
LIFEOS_CORS_ORIGINS=http://localhost:8094,http://127.0.0.1:8094
LIFEOS_AUTHORITY_PROVIDER=notion
NOTION_DATA_SOURCE_ID=
NOTION_TOKEN=
NOTION_WEBHOOK_SIGNING_SECRET=
GOOGLE_SHEETS_ACCESS_TOKEN=
# Optional local OAuth cache path; never commit the token file.
GOOGLE_SHEETS_TOKEN_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_DATA_SOURCE_ID=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=30000
LIFEOS_HEALTH_SNAPSHOTS_PATH=server-data/health-connect-snapshots.json
