# LifeOS server runtime. Inject secrets through the private agent environment.
PORT=8790
LIFEOS_SERVER_HOST=0.0.0.0
# Optional self-hosted connector authentication. Never treat an Expo public
# environment value as a secret or shared production credential.
LIFEOS_SERVER_TOKEN=
LIFEOS_MCP_TOKEN=
# Sheets webhook POSTs must carry Authorization: Bearer LIFEOS_SERVER_TOKEN.
# Provider writes may send expected_version or expected_digest for compare-and-set safety.
LIFEOS_CORS_ORIGINS=http://localhost:8094,http://127.0.0.1:8094
LIFEOS_AUTHORITY_PROVIDER=notion
NOTION_DATA_SOURCE_ID=
NOTION_TOKEN=
# Optional personal push sync only. Leave blank/false for release and FOSS builds.
LIFEOS_NOTION_WEBHOOKS_ENABLED=
NOTION_WEBHOOK_SIGNING_SECRET=
GOOGLE_SHEETS_ACCESS_TOKEN=
# Optional local OAuth cache path; never commit the token file.
GOOGLE_SHEETS_TOKEN_FILE=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_DATA_SOURCE_ID=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=30000
# Set true to let Responses use hosted web search; otherwise only explicit
# web/current/source queries opt in. URL citations are returned as source cards.
OPENAI_WEB_SEARCH_ENABLED=
OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium
OPENAI_WEB_SEARCH_TIMEOUT_MS=60000
LIFEOS_HEALTH_SNAPSHOTS_PATH=server-data/health-connect-snapshots.json
