{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderfood.app/schemas/chat-stream-event.v1.schema.json",
  "title": "LifeOS chat stream event",
  "oneOf": [
    {
      "type": "object",
      "required": ["type", "run_id", "conversation_id"],
      "properties": {
        "type": { "const": "run.start" },
        "run_id": { "type": "string", "minLength": 1 },
        "conversation_id": { "type": "string", "minLength": 1 },
        "thread_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "run_id", "conversation_id", "delta"],
      "properties": {
        "type": { "const": "token" },
        "run_id": { "type": "string", "minLength": 1 },
        "conversation_id": { "type": "string", "minLength": 1 },
        "delta": { "type": "string" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "run_id", "conversation_id", "response"],
      "properties": {
        "type": { "const": "run.end" },
        "run_id": { "type": "string", "minLength": 1 },
        "conversation_id": { "type": "string", "minLength": 1 },
        "response": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "conversation_id", "response"],
      "properties": {
        "type": { "const": "cache" },
        "conversation_id": { "type": "string", "minLength": 1 },
        "response": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "error"],
      "properties": {
        "type": { "const": "error" },
        "error": { "type": "string", "minLength": 1 },
        "conversation_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  ]
}
