{
  "schema_version": "lifeos.workflow.v1",
  "id": "weekly_food_reset",
  "domain": "food",
  "label": "Weekly food reset",
  "trigger": { "kind": "schedule", "expression": "SUN 18:00", "timezone": "user" },
  "steps": [
    { "id": "use_soon", "tool": "search", "input": { "collection": "inventory", "filter": "expires_within_5_days" } },
    { "id": "draft_meals", "skill": "food", "input_from": ["use_soon"], "output": "meal_plan" },
    { "id": "fill_gaps", "tool": "run_workflow", "input": { "workflow": "meal_plan_to_shopping" } },
    { "id": "summarize", "skill": "food", "input_from": ["use_soon", "draft_meals", "fill_gaps"], "output": "conversation_message" }
  ],
  "write_policy": "Reversible creates and updates may run directly and must emit Undo metadata. Purchases, deletes, credential changes and health-data exports require explicit confirmation."
}
