{
  "schema_version": "lifeos.workflow.v1",
  "id": "receipt_to_kitchen",
  "domain": "food",
  "label": "Receipt to kitchen",
  "steps": [
    { "id": "capture", "tool": "read_record", "input": { "collection": "purchase" } },
    { "id": "classify", "skill": "food", "input_from": ["capture"], "output": "purchase_line_classifications" },
    { "id": "reconcile", "tool": "update_record", "input_from": ["classify"], "output": "inventory_and_shopping_changes" },
    { "id": "receipt", "skill": "food", "input_from": ["reconcile"], "output": "conversation_message" }
  ],
  "write_policy": "Reversible inventory and shopping updates may run directly with Undo metadata. Unreadable lines remain in needs-review."
}
