{
  "schema_version": "lifeos.workflow.v1",
  "id": "meal_plan_to_shopping",
  "domain": "food",
  "label": "Meal plan to shopping",
  "steps": [
    { "id": "read_plan", "tool": "search", "input": { "collection": "meal_plan", "filter": "active_week" } },
    { "id": "read_kitchen", "tool": "search", "input": { "collection": "inventory", "filter": "available" } },
    { "id": "calculate_gaps", "skill": "food", "input_from": ["read_plan", "read_kitchen"], "output": "ingredient_gaps" },
    { "id": "update_shopping", "tool": "update_record", "input_from": ["calculate_gaps"], "output": "shopping_changes" }
  ],
  "write_policy": "Shopping creates and quantity updates are reversible and must include Undo metadata. Never place an order."
}
