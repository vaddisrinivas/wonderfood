{
  "provider": "notion",
  "schema_version": "lifeos.provider.notion.v1",
  "api": {
    "version": "2026-03-11",
    "base_path": "https://api.notion.com/v1",
    "write_parent": "data_source_id",
    "retry_enabled": true
  },
  "required_env": [
    "NOTION_TOKEN",
    "NOTION_DATA_SOURCE_ID"
  ],
  "webhook": {
    "signature_env": "NOTION_WEBHOOK_SIGNING_SECRET",
    "signature_header": "X-Notion-Signature",
    "dedupe_preference": [
      "event_id",
      "dedup_id",
      "external_id",
      "id"
    ],
    "id": {
      "external_prefix": "external"
    }
  },
  "operations": [
    "create_record",
    "update_record",
    "archive_record"
  ],
  "contracts": {
    "preserve_unsupported_fields": true,
    "source_snapshot_fields": [
      "provider",
      "data_source_id",
      "page_id",
      "block_id",
      "range"
    ]
  }
}
