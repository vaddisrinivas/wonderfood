{
  "$schema": "../schemas/agent-registry.v1.schema.json",
  "schema_version": "lifeos.agent-registry.v1",
  "agents": [
    {
      "id": "orchestrator",
      "version": "1.0.0",
      "role": "Conversation owner and bounded router",
      "domains": ["*"],
      "input_schema": "../schemas/agent-handoff.v1.schema.json",
      "output_schema": "../chat/chat-stream-event.v1.schema.json",
      "tools": ["retrieval", "domain_specialist", "planner", "executor", "citation_verifier"],
      "capabilities": [{ "domain": "*", "collections": ["*"], "ops": [] }],
      "risk": "read",
      "timeout_ms": 30000,
      "concurrency": 1,
      "model_class": "reasoning",
      "fallback": "return_partial_with_warning"
    },
    {
      "id": "retrieval",
      "version": "1.0.0",
      "role": "Minimum relevant source selector",
      "domains": ["*"],
      "input_schema": "../schemas/agent-handoff.v1.schema.json",
      "output_schema": "../schemas/record.v1.schema.json",
      "tools": ["search", "read_record", "provider_pull"],
      "capabilities": [{ "domain": "*", "collections": ["*"], "ops": [] }],
      "risk": "read",
      "timeout_ms": 12000,
      "concurrency": 4,
      "model_class": "fast",
      "fallback": "use_local_snapshot"
    },
    {
      "id": "domain_specialist",
      "version": "1.0.0",
      "role": "Domain skill interpreter",
      "domains": ["food", "health", "plants"],
      "input_schema": "../schemas/agent-handoff.v1.schema.json",
      "output_schema": "../chat/chat-stream-event.v1.schema.json",
      "tools": ["domain_manifest", "skill", "schema"],
      "capabilities": [{ "domain": "*", "collections": ["*"], "ops": [] }],
      "risk": "read",
      "timeout_ms": 12000,
      "concurrency": 2,
      "model_class": "reasoning",
      "fallback": "ask_one_focused_question"
    },
    {
      "id": "planner",
      "version": "1.0.0",
      "role": "Typed command and workflow planner",
      "domains": ["*"],
      "input_schema": "../schemas/command.v1.schema.json",
      "output_schema": "../schemas/command.v1.schema.json",
      "tools": ["schema", "workflow"] ,
      "capabilities": [{ "domain": "*", "collections": ["*"], "ops": [] }],
      "risk": "reversible_write",
      "timeout_ms": 12000,
      "concurrency": 1,
      "model_class": "reasoning",
      "fallback": "review_only"
    },
    {
      "id": "executor",
      "version": "1.0.0",
      "role": "Validated action executor",
      "domains": ["*"],
      "input_schema": "../schemas/command.v1.schema.json",
      "output_schema": "../schemas/action-event.v1.schema.json",
      "tools": ["create_record", "update_record", "archive_record", "run_workflow"],
      "capabilities": [{ "domain": "*", "collections": ["*"], "ops": ["create", "update", "archive", "restore", "relate", "unrelate", "delete"] }],
      "risk": "reversible_write",
      "timeout_ms": 20000,
      "concurrency": 1,
      "model_class": "deterministic",
      "fallback": "return_failed_receipt"
    },
    {
      "id": "citation_verifier",
      "version": "1.0.0",
      "role": "Claim-to-source verifier",
      "domains": ["*"],
      "input_schema": "../schemas/agent-handoff.v1.schema.json",
      "output_schema": "../schemas/source-snapshot.v1.schema.json",
      "tools": ["read_record", "source_snapshot"],
      "capabilities": [{ "domain": "*", "collections": ["*"], "ops": [] }],
      "risk": "read",
      "timeout_ms": 8000,
      "concurrency": 4,
      "model_class": "fast",
      "fallback": "strip_unsupported_claims"
    },
    {
      "id": "sync_steward",
      "version": "1.0.0",
      "role": "Provider pull and deterministic merge",
      "domains": ["*"],
      "input_schema": "../schemas/agent-handoff.v1.schema.json",
      "output_schema": "../schemas/action-event.v1.schema.json",
      "tools": ["provider_pull", "provider_webhook", "source_snapshot"],
      "capabilities": [{ "domain": "*", "collections": ["*"], "ops": ["create", "update", "archive", "restore", "relate", "unrelate"] }],
      "risk": "reversible_write",
      "timeout_ms": 30000,
      "concurrency": 1,
      "model_class": "deterministic",
      "fallback": "retain_previous_canonical_state"
    }
  ]
}
