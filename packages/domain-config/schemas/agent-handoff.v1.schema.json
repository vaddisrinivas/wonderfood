{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderfood.app/schemas/agent-handoff.v1.schema.json",
  "title": "LifeOS agent handoff",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "run_id",
    "role",
    "status",
    "input_schema",
    "output_schema",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "lifeos.agent-handoff.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "blocked", "failed", "timed_out", "canceled"]
    },
    "input_schema": {
      "type": "string",
      "minLength": 1
    },
    "output_schema": {
      "type": "string",
      "minLength": 1
    },
    "tool_names": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "result": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "duration_ms": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "reason": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
