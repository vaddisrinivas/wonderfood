{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderfood.app/schemas/undo.v1.schema.json",
  "title": "LifeOS undo envelope",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "action_id",
    "status",
    "payload",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "lifeos.undo.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["ready", "consumed", "expired", "missing"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
