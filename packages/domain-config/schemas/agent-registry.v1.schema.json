{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderfood.app/schemas/agent-registry.v1.schema.json",
  "title": "LifeOS agent registry",
  "type": "object",
  "required": ["schema_version", "agents"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "lifeos.agent-registry.v1" },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "version", "role", "domains", "input_schema", "output_schema", "tools", "capabilities", "risk", "timeout_ms", "concurrency", "model_class", "fallback"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "domains": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "input_schema": { "type": "string", "minLength": 1 },
          "output_schema": { "type": "string", "minLength": 1 },
          "tools": { "type": "array", "items": { "type": "string" } },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["domain", "collections", "ops"],
              "properties": {
                "domain": { "type": "string", "minLength": 1 },
                "collections": { "type": "array", "items": { "type": "string", "minLength": 1 } },
                "ops": {
                  "type": "array",
                  "items": { "enum": ["create", "update", "archive", "restore", "relate", "unrelate", "delete"] },
                  "uniqueItems": true
                }
              },
              "additionalProperties": false
            }
          },
          "risk": { "enum": ["read", "reversible_write", "sensitive"] },
          "timeout_ms": { "type": "integer", "minimum": 1 },
          "concurrency": { "type": "integer", "minimum": 1 },
          "model_class": { "type": "string", "minLength": 1 },
          "fallback": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
