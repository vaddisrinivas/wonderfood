{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderfood.app/schemas/domain-catalog.v1.schema.json",
  "title": "LifeOS domain catalog",
  "type": "object",
  "required": ["schema_version", "shell_version", "active_domain_id", "shell", "domains"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "lifeos.domain-catalog.v1" },
    "shell_version": { "const": "lifeos.shell.v1" },
    "active_domain_id": { "type": "string" },
    "shell": {
      "type": "object",
      "required": ["tabs", "global_actions", "action_policy"],
      "properties": {
        "tabs": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
        "global_actions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "action_policy": { "type": "string" }
      },
      "additionalProperties": false
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "icon", "status", "summary"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "icon": { "type": "string" },
          "status": { "enum": ["active", "ready", "preview", "disabled"] },
          "manifest": { "type": "string" },
          "skill": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
