{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderfood.app/schemas/record.v1.schema.json",
  "title": "LifeOS canonical record",
  "type": "object",
  "required": ["id", "domain", "collection", "title", "properties", "source", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "collection": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "properties": { "type": "object" },
    "relations": { "type": "array", "items": { "$ref": "#/$defs/relation" } },
    "source": { "$ref": "#/$defs/source" },
    "archived_at": { "type": ["string", "null"], "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "relation": {
      "type": "object",
      "required": ["name", "target_id"],
      "properties": { "name": { "type": "string" }, "target_id": { "type": "string" } },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["provider", "external_id", "observed_at"],
      "properties": {
        "provider": { "enum": ["notion", "google_sheets", "sqlite", "postgres", "web", "user"] },
        "external_id": { "type": "string" },
        "url": { "type": ["string", "null"], "format": "uri" },
        "observed_at": { "type": "string", "format": "date-time" },
        "content_hash": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
