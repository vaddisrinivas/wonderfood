{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderfood.app/schemas/workflow.v1.schema.json",
  "title": "LifeOS workflow",
  "type": "object",
  "required": ["schema_version", "id", "domain", "label", "steps", "write_policy"],
  "properties": {
    "schema_version": { "const": "lifeos.workflow.v1" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "domain": { "type": "string" },
    "label": { "type": "string" },
    "trigger": { "type": "object" },
    "steps": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["id"] } },
    "write_policy": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
