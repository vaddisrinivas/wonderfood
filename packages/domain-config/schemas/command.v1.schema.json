{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderfood.app/schemas/command.v1.schema.json",
  "title": "LifeOS command envelope",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "actor",
    "domain",
    "tool",
    "action",
    "risk",
    "payload",
    "created_at",
    "idempotency_key"
  ],
  "properties": {
    "schema_version": {
      "const": "lifeos.command.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "enum": ["low", "standard", "sensitive", "irreversible", "restricted"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "requires_clarification": {
      "type": "boolean",
      "default": false
    },
    "clarification_question": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
