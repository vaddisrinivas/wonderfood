{
  "$schema": "../schemas/domain.v1.schema.json",
  "schema_version": "lifeos.domain.v1",
  "id": "food",
  "label": "Food",
  "home_surface": "food.overview",
  "surfaces": [
    {
      "id": "food.overview",
      "label": "Overview",
      "icon": "🏡",
      "views": ["next_meal", "use_soon", "shopping_summary", "food_graph"],
      "collections": []
    },
    {
      "id": "food.meals",
      "label": "Meals",
      "icon": "🍽️",
      "views": ["planner", "week_view", "meal_history", "nutrition_summary", "recipe_revisions"],
      "collections": ["meal_plan", "meal_log", "meal_consumption", "recipe", "recipe_revision", "recipe_step"]
    },
    {
      "id": "food.kitchen",
      "label": "Kitchen",
      "icon": "🥬",
      "views": ["pantry", "lots", "movements", "products", "pantry_stats", "inventory_trends"],
      "collections": ["food_item", "product", "inventory", "inventory_lot", "inventory_movement", "ingredient", "purchase_line"]
    },
    {
      "id": "food.shopping",
      "label": "Shopping",
      "icon": "🛒",
      "views": ["list", "demand", "stores", "budget", "status_board", "receipt_review"],
      "collections": ["shopping_list", "shopping_item", "shopping_demand", "purchase", "purchase_line", "store"]
    }
  ],
  "collections": [
    "household",
