  "dashboard_blocks": [
    {
      "id": "food:tonight",
      "surface": "food.overview",
      "title": "Tonight decision",
      "subtitle": "Meal plan, recipe and next cooking step.",
      "kind": "spotlight",
      "tone": "moss",
      "size": "standard",
      "query": { "collections": ["meal_plan", "recipe"], "match": "planned|tonight|dinner|high protein", "limit": 1 },
      "href": "/chat"
    },
    {
      "id": "food:nutrition",
      "surface": "food.overview",
      "title": "Nutrition lens",
      "subtitle": "Protein, calories, fiber and serving context from rich detail.",
      "kind": "metric",
      "tone": "plum",
      "size": "wide",
      "query": { "collections": ["recipe", "recipe_revision", "meal_plan", "meal_consumption", "nutrition_profile", "nutrition_observation", "nutrition_goal"], "match": "protein|nutrition|fiber|calorie|serving|goal", "limit": 2 },
      "href": "/search"
    },
    {
      "id": "food:lots",
      "surface": "food.kitchen",
      "title": "Lots and movements",
      "subtitle": "Open packages, expiry, purchase source and consumption/waste ledger.",
      "kind": "list",
      "tone": "moss",
      "size": "wide",
      "query": { "collections": ["inventory_lot", "inventory_movement", "product"], "match": "open|sealed|frozen|depleted|waste|expiry|lot", "limit": 4 },
      "href": "/search"
    },
    {
      "id": "food:use-soon",
      "surface": "food.kitchen",
      "title": "Use-first queue",
      "subtitle": "Food most likely to expire or unlock a planned meal.",
      "kind": "list",
      "tone": "amber",
      "size": "standard",
      "query": { "collections": ["inventory", "inventory_lot", "ingredient"], "match": "use soon|expire|pantry|available|yogurt|best by|use by", "limit": 4 },
      "href": "/capture"
    },
    {
      "id": "food:shopping",
      "surface": "food.shopping",
      "title": "Shopping gaps",
      "subtitle": "Needed, in cart, bought and why each item exists.",
      "kind": "list",
      "tone": "blue",
      "size": "standard",
      "query": { "collections": ["shopping_list", "shopping_item", "shopping_demand", "purchase_line", "purchase"], "match": "to buy|shopping|needed|missing|demand|cart", "limit": 4 },
      "href": "/capture"
    },
    {
      "id": "food:spending",
      "surface": "food.shopping",
      "title": "Spend and receipt health",
      "subtitle": "Purchase totals, line prices, returns and category/waste signals.",
      "kind": "metric",
      "tone": "plum",
      "size": "standard",
      "query": { "collections": ["purchase", "purchase_line", "inventory_movement"], "match": "total|tax|discount|merchant|waste|return|price", "limit": 3 },
      "href": "/sources"
    },
    {
      "id": "food:sources",
      "surface": "food.overview",
      "title": "Source trust",
      "subtitle": "Notion, Sheets, SQLite and Postgres feed one canonical graph.",
      "kind": "action",
      "tone": "neutral",
      "size": "compact",
      "query": { "collections": ["source_record"], "match": "notion|sheets|sqlite|postgres", "limit": 3 },
      "href": "/sources"
    }
  ],
