{
  "$schema": "../schemas/domain.v1.schema.json",
  "schema_version": "lifeos.domain.v1",
  "id": "food",
  "label": "Food",
  "home_surface": "food.overview",
  "surfaces": [
    {
      "id": "food.overview",
      "label": "Overview",
      "views": ["next_meal", "use_soon", "shopping_summary", "food_graph"],
      "collections": []
    },
    {
      "id": "food.meals",
      "label": "Meals",
      "views": ["planner", "week_view", "nutrition_summary"],
      "collections": ["meal_plan", "meal_log", "recipe"]
    },
    {
      "id": "food.kitchen",
      "label": "Kitchen",
      "views": ["pantry", "pantry_stats", "inventory_trends"],
      "collections": ["inventory", "ingredient", "purchase_line"]
    },
    {
      "id": "food.shopping",
      "label": "Shopping",
      "views": ["list", "stores", "budget", "status_board"],
      "collections": ["shopping_item", "purchase", "store"]
    }
  ],
  "collections": [
    "inventory",
    "ingredient",
    "recipe",
    "meal_plan",
    "meal_log",
    "shopping_item",
    "purchase",
    "purchase_line",
    "store",
    "preference",
    "nutrition_observation",
    "source_record"
  ],
  "rich_detail_schema": "schemas/food-detail.v1.schema.json",
  "provider_template_fields": {
    "required": ["id", "title", "collection", "status", "meta", "body"],
    "rich_detail_json": ["Food detail", "food_detail", "Food Detail", "Detail JSON", "detail_json"],
    "relations_json": ["Relations", "relations", "Related records", "related_records"]
  },
  "dashboard_blocks": [
    {
      "id": "food:tonight",
      "surface": "food.overview",
      "title": "Tonight decision",
      "subtitle": "Meal plan, recipe and next cooking step.",
      "kind": "spotlight",
      "tone": "moss",
      "query": { "collections": ["meal_plan", "recipe"], "match": "planned|tonight|dinner|high protein", "limit": 1 },
      "href": "/chat"
    },
    {
      "id": "food:nutrition",
      "surface": "food.overview",
      "title": "Nutrition lens",
      "subtitle": "Protein, calories, fiber and serving context from rich detail.",
      "kind": "metric",
      "tone": "plum",
      "query": { "collections": ["recipe", "meal_plan", "nutrition_observation"], "match": "protein|nutrition|fiber|calorie", "limit": 2 },
      "href": "/search"
    },
    {
      "id": "food:use-soon",
      "surface": "food.kitchen",
      "title": "Use-first queue",
      "subtitle": "Food most likely to expire or unlock a planned meal.",
      "kind": "list",
      "tone": "amber",
      "query": { "collections": ["inventory", "ingredient"], "match": "use soon|expire|pantry|available|yogurt", "limit": 4 },
      "href": "/capture"
    },
    {
      "id": "food:shopping",
      "surface": "food.shopping",
      "title": "Shopping gaps",
      "subtitle": "Needed, in cart, bought and why each item exists.",
      "kind": "list",
      "tone": "blue",
      "query": { "collections": ["shopping_item", "purchase_line", "purchase"], "match": "to buy|shopping|needed|missing", "limit": 4 },
      "href": "/capture"
    },
    {
      "id": "food:sources",
      "surface": "food.overview",
      "title": "Source trust",
      "subtitle": "Notion, Sheets, SQLite and Postgres feed one canonical graph.",
      "kind": "action",
      "tone": "neutral",
      "query": { "collections": ["source_record"], "match": "notion|sheets|sqlite|postgres", "limit": 3 },
      "href": "/sources"
    }
  ],
  "relations": [
    { "from": "inventory", "to": "ingredient", "name": "represents" },
    { "from": "recipe", "to": "ingredient", "name": "uses" },
    { "from": "meal_plan", "to": "recipe", "name": "plans" },
    { "from": "meal_log", "to": "meal_plan", "name": "completes" },
    { "from": "shopping_item", "to": "inventory", "name": "restocks" },
    { "from": "purchase_line", "to": "shopping_item", "name": "fulfills" },
    { "from": "purchase_line", "to": "inventory", "name": "adds" },
    { "from": "nutrition_observation", "to": "meal_log", "name": "describes" },
    { "from": "source_record", "to": "*", "name": "supports" }
  ],
  "skills": ["food"],
  "workflows": ["weekly_food_reset", "receipt_to_kitchen", "meal_plan_to_shopping", "phase4_replay_workflow", "phase4_compensation_probe"],
  "data_homes": ["notion", "google_sheets", "sqlite", "postgres"],
  "mcp": {
    "resources": ["domain_manifest", "schema", "record", "source_snapshot", "conversation"],
    "tools": ["search", "read_record", "create_record", "update_record", "archive_record", "run_workflow"]
  }
}
