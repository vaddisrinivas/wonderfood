{
  "$schema": "../schemas/domain.v1.schema.json",
  "schema_version": "lifeos.domain.v1",
  "id": "food",
  "label": "Food",
  "home_surface": "food.overview",
  "surfaces": [
    {
      "id": "food.overview",
      "label": "Overview",
      "views": ["next_meal", "use_soon", "shopping_summary", "food_graph"],
      "collections": []
    },
    {
      "id": "food.meals",
      "label": "Meals",
      "views": ["planner", "week_view", "meal_history", "nutrition_summary", "recipe_revisions"],
      "collections": ["meal_plan", "meal_log", "meal_consumption", "recipe", "recipe_revision", "recipe_step"]
    },
    {
      "id": "food.kitchen",
      "label": "Kitchen",
      "views": ["pantry", "lots", "movements", "products", "pantry_stats", "inventory_trends"],
      "collections": ["food_item", "product", "inventory", "inventory_lot", "inventory_movement", "ingredient", "purchase_line"]
    },
    {
      "id": "food.shopping",
      "label": "Shopping",
      "views": ["list", "demand", "stores", "budget", "status_board", "receipt_review"],
      "collections": ["shopping_list", "shopping_item", "shopping_demand", "purchase", "purchase_line", "store"]
    }
  ],
  "collections": [
    "household",
    "member",
    "food_item",
    "product",
    "inventory",
    "inventory_lot",
    "inventory_movement",
    "ingredient",
    "recipe",
    "recipe_revision",
    "recipe_step",
    "recipe_tool",
    "meal_template",
    "meal_plan",
    "meal_log",
    "meal_consumption",
    "shopping_list",
    "shopping_item",
    "shopping_demand",
    "purchase",
    "purchase_line",
    "store",
    "preference",
    "nutrition_goal",
    "nutrition_profile",
    "nutrition_observation",
    "attachment",
    "audit_event",
    "source_record"
  ],
  "rich_detail_schema": "schemas/food-detail.v1.schema.json",
  "provider_template_fields": {
    "required": ["id", "title", "collection", "status", "meta", "body"],
    "rich_detail_json": ["Food detail", "food_detail", "Food Detail", "Detail JSON", "detail_json"],
    "relations_json": ["Relations", "relations", "Related records", "related_records"]
  },
  "dashboard_blocks": [
    {
      "id": "food:tonight",
      "surface": "food.overview",
      "title": "Tonight decision",
      "subtitle": "Meal plan, recipe and next cooking step.",
      "kind": "spotlight",
      "tone": "moss",
      "query": { "collections": ["meal_plan", "recipe"], "match": "planned|tonight|dinner|high protein", "limit": 1 },
      "href": "/chat"
    },
    {
      "id": "food:nutrition",
      "surface": "food.overview",
      "title": "Nutrition lens",
      "subtitle": "Protein, calories, fiber and serving context from rich detail.",
      "kind": "metric",
      "tone": "plum",
      "query": { "collections": ["recipe", "recipe_revision", "meal_plan", "meal_consumption", "nutrition_profile", "nutrition_observation", "nutrition_goal"], "match": "protein|nutrition|fiber|calorie|serving|goal", "limit": 2 },
      "href": "/search"
    },
    {
      "id": "food:lots",
      "surface": "food.kitchen",
      "title": "Lots and movements",
      "subtitle": "Open packages, expiry, purchase source and consumption/waste ledger.",
      "kind": "list",
      "tone": "moss",
      "query": { "collections": ["inventory_lot", "inventory_movement", "product"], "match": "open|sealed|frozen|depleted|waste|expiry|lot", "limit": 4 },
      "href": "/search"
    },
    {
      "id": "food:use-soon",
      "surface": "food.kitchen",
      "title": "Use-first queue",
      "subtitle": "Food most likely to expire or unlock a planned meal.",
      "kind": "list",
      "tone": "amber",
      "query": { "collections": ["inventory", "inventory_lot", "ingredient"], "match": "use soon|expire|pantry|available|yogurt|best by|use by", "limit": 4 },
      "href": "/capture"
    },
    {
      "id": "food:shopping",
      "surface": "food.shopping",
      "title": "Shopping gaps",
      "subtitle": "Needed, in cart, bought and why each item exists.",
      "kind": "list",
      "tone": "blue",
      "query": { "collections": ["shopping_list", "shopping_item", "shopping_demand", "purchase_line", "purchase"], "match": "to buy|shopping|needed|missing|demand|cart", "limit": 4 },
      "href": "/capture"
    },
    {
      "id": "food:spending",
      "surface": "food.shopping",
      "title": "Spend and receipt health",
      "subtitle": "Purchase totals, line prices, returns and category/waste signals.",
      "kind": "metric",
      "tone": "plum",
      "query": { "collections": ["purchase", "purchase_line", "inventory_movement"], "match": "total|tax|discount|merchant|waste|return|price", "limit": 3 },
      "href": "/sources"
    },
    {
      "id": "food:sources",
      "surface": "food.overview",
      "title": "Source trust",
      "subtitle": "Notion, Sheets, SQLite and Postgres feed one canonical graph.",
      "kind": "action",
      "tone": "neutral",
      "query": { "collections": ["source_record"], "match": "notion|sheets|sqlite|postgres", "limit": 3 },
      "href": "/sources"
    }
  ],
  "relations": [
    { "from": "household", "to": "member", "name": "has_member" },
    { "from": "member", "to": "preference", "name": "has_preference" },
    { "from": "member", "to": "nutrition_goal", "name": "has_goal" },
    { "from": "food_item", "to": "preference", "name": "shaped_by" },
    { "from": "product", "to": "food_item", "name": "packages" },
    { "from": "product", "to": "nutrition_profile", "name": "has_label_nutrition" },
    { "from": "inventory", "to": "food_item", "name": "tracks" },
    { "from": "inventory", "to": "ingredient", "name": "represents" },
    { "from": "inventory_lot", "to": "food_item", "name": "stores" },
    { "from": "inventory_lot", "to": "product", "name": "from_product" },
    { "from": "inventory_lot", "to": "purchase_line", "name": "acquired_from" },
    { "from": "inventory_movement", "to": "inventory_lot", "name": "moves" },
    { "from": "inventory_movement", "to": "meal_log", "name": "caused_by_meal" },
    { "from": "ingredient", "to": "food_item", "name": "matches_food" },
    { "from": "recipe", "to": "ingredient", "name": "uses" },
    { "from": "recipe", "to": "recipe_revision", "name": "has_revision" },
    { "from": "recipe_revision", "to": "recipe_step", "name": "contains_step" },
    { "from": "recipe", "to": "recipe_step", "name": "has_step" },
    { "from": "recipe", "to": "recipe_tool", "name": "uses_tool" },
    { "from": "recipe", "to": "nutrition_profile", "name": "has_nutrition" },
    { "from": "meal_template", "to": "recipe", "name": "templates" },
    { "from": "meal_plan", "to": "recipe", "name": "plans" },
    { "from": "meal_plan", "to": "meal_template", "name": "uses_template" },
    { "from": "meal_log", "to": "meal_plan", "name": "completes" },
    { "from": "meal_consumption", "to": "meal_log", "name": "portion_of" },
    { "from": "meal_consumption", "to": "member", "name": "eaten_by" },
    { "from": "shopping_list", "to": "meal_plan", "name": "supports_plan" },
    { "from": "shopping_item", "to": "shopping_list", "name": "belongs_to" },
    { "from": "shopping_item", "to": "inventory", "name": "restocks" },
    { "from": "shopping_item", "to": "food_item", "name": "buys_food" },
    { "from": "shopping_demand", "to": "shopping_item", "name": "explains" },
    { "from": "shopping_demand", "to": "ingredient", "name": "from_ingredient" },
    { "from": "shopping_demand", "to": "meal_plan", "name": "from_plan" },
    { "from": "purchase_line", "to": "shopping_item", "name": "fulfills" },
    { "from": "purchase_line", "to": "inventory", "name": "adds" },
    { "from": "purchase_line", "to": "inventory_lot", "name": "creates_lot" },
    { "from": "purchase_line", "to": "product", "name": "bought_product" },
    { "from": "purchase_line", "to": "purchase", "name": "part_of" },
    { "from": "nutrition_observation", "to": "meal_log", "name": "describes" },
    { "from": "nutrition_observation", "to": "nutrition_profile", "name": "uses_profile" },
    { "from": "attachment", "to": "*", "name": "attached_to" },
    { "from": "audit_event", "to": "*", "name": "records_change" },
    { "from": "source_record", "to": "*", "name": "supports" }
  ],
  "skills": ["food"],
  "workflows": ["weekly_food_reset", "receipt_to_kitchen", "meal_plan_to_shopping", "phase4_replay_workflow", "phase4_compensation_probe"],
  "data_homes": ["notion", "google_sheets", "sqlite", "postgres"],
  "mcp": {
    "resources": ["domain_manifest", "schema", "record", "source_snapshot", "conversation"],
    "tools": ["search", "read_record", "create_record", "update_record", "archive_record", "run_workflow"]
  }
}
