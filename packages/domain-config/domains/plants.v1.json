      "plant_brain": { "emoji": "✦", "accent": "moss" },
      "source_steward": { "emoji": "🔗", "accent": "blue" }
    }
  },
  "dashboard_blocks": [
    {
      "id": "plants:attention",
      "surface": "plants.overview",
      "title": "Needs attention",
      "subtitle": "Plants, care tasks and observations that should surface first.",
      "kind": "spotlight",
      "tone": "blue",
      "size": "standard",
      "query": { "collections": ["plant", "care_task"], "match": "water|light|attention|care|today", "limit": 1 },
      "href": "/chat"
    },
    {
      "id": "plants:watering",
      "surface": "plants.overview",
      "title": "Care rhythm",
      "subtitle": "Watering, feeding and room-level care tasks.",
      "kind": "list",
      "tone": "moss",
      "size": "wide",
      "query": { "collections": ["care_task", "plant_journal"], "match": "water|feed|rotate|journal", "limit": 4 },
      "href": "/capture"
    },
    {
      "id": "plants:supplies",
      "surface": "plants.supplies",
      "title": "Supply gaps",
      "subtitle": "Soil, pots, fertilizer and plant-care supplies.",
      "kind": "list",
      "tone": "amber",
      "size": "standard",
      "query": { "collections": ["plant_supply"], "match": "buy|low|needed|supply", "limit": 4 },
      "href": "/sources"
    }
  ],
  "relations": [
    { "from": "care_task", "to": "plant", "name": "cares_for" },
    { "from": "plant_observation", "to": "plant", "name": "observes" },
    { "from": "plant_supply", "to": "plant", "name": "supports" },
    { "from": "source_record", "to": "*", "name": "supports" }
  ],
  "skills": ["plants"],
  "workflows": [],
  "data_homes": ["notion", "google_sheets", "sqlite", "postgres"],
  "mcp": {
    "resources": ["domain_manifest", "schema", "record", "source_snapshot", "conversation"],
    "tools": ["search", "read_record", "create_record", "update_record", "archive_record"]
  }
}
