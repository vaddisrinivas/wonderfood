{
  "$schema": "../schemas/domain.v1.schema.json",
  "schema_version": "lifeos.domain.v1",
  "id": "plants",
  "label": "Plants",
  "home_surface": "plants.overview",
  "surfaces": [
    { "id": "plants.overview", "label": "Overview", "views": ["needs_attention", "watering", "growth"], "collections": ["plant", "care_task"] },
    { "id": "plants.journal", "label": "Journal", "views": ["timeline", "observations"], "collections": ["plant_observation", "plant_journal"] },
    { "id": "plants.supplies", "label": "Supplies", "views": ["inventory", "to_buy"], "collections": ["plant_supply"] }
  ],
  "collections": ["plant", "care_task", "plant_observation", "plant_journal", "plant_supply", "source_record"],
  "visual_identity": {
    "domain": { "emoji": "🌿", "accent": "moss" },
    "surfaces": {
      "plants.overview": { "emoji": "🌱", "accent": "moss" },
      "plants.journal": { "emoji": "📓", "accent": "blue" },
      "plants.supplies": { "emoji": "🪴", "accent": "amber" }
    },
    "collections": {
      "plant": { "emoji": "🌿", "accent": "moss" },
      "care_task": { "emoji": "💧", "accent": "blue" },
      "plant_observation": { "emoji": "🔎", "accent": "plum" },
      "plant_journal": { "emoji": "📓", "accent": "blue" },
      "plant_supply": { "emoji": "🪴", "accent": "amber" },
      "source_record": { "emoji": "🔗", "accent": "neutral" }
    },
    "statuses": {
      "active": { "emoji": "✅", "accent": "moss" },
      "needs_attention": { "emoji": "❗", "accent": "amber" },
      "water": { "emoji": "💧", "accent": "blue" },
      "growth": { "emoji": "🌱", "accent": "moss" }
    },
    "actions": {
      "home": { "emoji": "⌂", "accent": "moss" },
      "add_record": { "emoji": "＋", "accent": "moss" },
      "capture": { "emoji": "＋", "accent": "moss" },
      "ask_with_collection": { "emoji": "✦", "accent": "plum" },
      "chat": { "emoji": "✦", "accent": "plum" },
      "search": { "emoji": "⌕", "accent": "blue" },
      "open_sources": { "emoji": "🔗", "accent": "neutral" },
      "settings": { "emoji": "⚙", "accent": "neutral" },
      "add_domain": { "emoji": "＋", "accent": "plum" },
      "review": { "emoji": "👀", "accent": "amber" },
      "refresh": { "emoji": "↻", "accent": "blue" },
      "capture_note": { "emoji": "📝", "accent": "neutral" },
      "capture_food": { "emoji": "🌿", "accent": "moss" },
      "capture_photo": { "emoji": "▧", "accent": "blue" },
      "capture_receipt": { "emoji": "🧾", "accent": "plum" },
      "capture_voice": { "emoji": "◖", "accent": "amber" },
      "capture_link": { "emoji": "⌁", "accent": "blue" }
    },
    "sources": {
      "notion": { "emoji": "◨", "accent": "neutral" },
      "google_sheets": { "emoji": "▦", "accent": "moss" },
      "sqlite": { "emoji": "▣", "accent": "blue" },
      "postgres": { "emoji": "⬢", "accent": "plum" },
      "web": { "emoji": "🌐", "accent": "blue" },
      "user": { "emoji": "🙂", "accent": "moss" }
    },
    "skills": {
      "plants": { "emoji": "🌿", "accent": "moss" },
      "source_verifier": { "emoji": "🔎", "accent": "blue" }
