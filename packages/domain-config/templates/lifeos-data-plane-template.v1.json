{
  "$schema": "./lifeos-data-plane-template.v1.schema.json",
  "schema_version": "lifeos.data_plane_template.v1",
  "id": "lifeos-2026-food-first",
  "title": "LifeOS 2026 Food-first Data Plane",
  "status": "source_template_model",
  "principles": [
    "One canonical record meaning across app, Notion, Sheets, SQLite, Postgres, AI and MCP.",
    "Notion is the beautiful human data plane; Sheets is the structured workbook data plane.",
    "Every surface can run alone. No hosted bridge, webhook, tunnel, Mac, model or vendor is mandatory.",
    "Food is the Day 0 domain; future domains install by manifest, schema and presentation profile."
  ],
  "authority_modes": [
    "sqlite_only",
    "notion_authority",
    "sheets_authority",
    "postgres_authority",
    "projection_mode"
  ],
  "notion": {
    "template_name": "LifeOS 2026",
    "max_navigation_depth": 3,
    "home_page": {
      "title": "Today",
      "job": "Decision-first personal command center: today, dinner, review, use-soon, sources and quick capture.",
      "sections": [
        "Today decision",
        "Food command center",
        "Use-first queue",
        "Review before writing",
        "Ask LifeOS",
        "Connected sources",
        "This week"
      ]
    },
    "pages": [
      {
        "id": "today",
        "title": "Today",
        "depth": 1,
        "kind": "dashboard",
        "contains": ["food_command_center", "review_queue", "source_health", "quick_capture"]
      },
      {
        "id": "food_command_center",
        "title": "Food",
        "depth": 1,
        "kind": "domain_home",
        "contains": ["meals", "kitchen", "recipes", "shopping", "purchases", "food_memory"]
      },
      {
        "id": "sources_and_sync",
        "title": "Sources",
        "depth": 1,
        "kind": "trust_center",
        "contains": ["source_records", "template_health", "sync_receipts", "schema_registry"]
      },
      {
        "id": "settings",
        "title": "Settings",
        "depth": 1,
        "kind": "control_plane",
        "contains": ["providers", "domains", "skills", "schemas", "workflows", "appearance"]
      },
      {
        "id": "meals",
        "title": "Meals",
        "depth": 2,
        "kind": "workspace",
        "contains": ["meal_plan", "meal_template", "meal_log", "meal_consumption"]
      },
      {
        "id": "kitchen",
        "title": "Kitchen",
        "depth": 2,
        "kind": "workspace",
        "contains": ["food_item", "product", "inventory", "inventory_lot", "inventory_movement", "ingredient"]
      },
      {
        "id": "recipes",
        "title": "Recipes",
        "depth": 2,
        "kind": "workspace",
        "contains": ["recipe", "recipe_revision", "recipe_step", "recipe_tool", "nutrition_profile"]
      },
      {
        "id": "shopping",
        "title": "Shopping",
        "depth": 2,
        "kind": "workspace",
        "contains": ["shopping_list", "shopping_item", "shopping_demand", "store"]
      },
      {
        "id": "purchases",
        "title": "Purchases",
        "depth": 2,
        "kind": "workspace",
        "contains": ["purchase", "purchase_line", "attachment"]
      },
      {
        "id": "household",
        "title": "Household",
        "depth": 2,
        "kind": "context",
        "contains": ["household", "member", "preference", "nutrition_goal", "nutrition_observation"]
      },
      {
        "id": "schema_registry",
        "title": "Schema registry",
        "depth": 2,
        "kind": "advanced",
        "contains": ["audit_event", "source_record"]
      }
    ],
    "databases": [
      {
        "id": "canonical_records",
        "name": "LifeOS Records",
        "job": "Single canonical table for import/export, app sync and external AI citations.",
        "collections": ["*"],
        "required_properties": ["Name", "_ID", "_Domain", "_Collection", "Status", "Meta", "Body", "Food detail", "Relations", "Source", "Source version", "Archived at"]
      },
      {
        "id": "kitchen",
        "name": "Kitchen",
        "job": "Pantry, product identity, lots, expiry and movement ledger.",
        "collections": ["food_item", "product", "inventory", "inventory_lot", "inventory_movement", "ingredient", "purchase_line"],
        "views": ["Use first", "By location", "Lots", "Movements", "Products", "Receipt-created"]
      },
      {
        "id": "recipes",
        "name": "Recipes",
        "job": "Recipes, revisions, steps, tools, substitutions and nutrition profiles.",
        "collections": ["recipe", "recipe_revision", "recipe_step", "recipe_tool", "nutrition_profile"],
        "views": ["Recipe gallery", "Current revisions", "Steps", "Tools", "High protein", "Needs ingredient"]
      },
      {
        "id": "meals",
        "name": "Meals",
        "job": "Meal planning, meal memory, servings, portions and Health context.",
        "collections": ["meal_template", "meal_plan", "meal_log", "meal_consumption", "nutrition_observation"],
        "views": ["This week", "Tonight", "Cooked", "Skipped", "Nutrition rollup"]
      },
      {
        "id": "shopping",
        "name": "Shopping",
        "job": "Lists, cart state, demand reasons, stores and purchase follow-through.",
        "collections": ["shopping_list", "shopping_item", "shopping_demand", "store", "purchase_line"],
        "views": ["To buy", "In cart", "Demand reasons", "By store", "Bought"]
      },
      {
        "id": "purchases",
        "name": "Purchases",
        "job": "Receipts, line items, price memory, returns, waste and attachments.",
        "collections": ["purchase", "purchase_line", "inventory_movement", "attachment"],
        "views": ["Receipt review", "Line prices", "By merchant", "Returns/waste", "Unmatched"]
      },
      {
        "id": "household",
        "name": "Household",
        "job": "Members, preferences, goals and constraints used by Food decisions.",
        "collections": ["household", "member", "preference", "nutrition_goal"],
        "views": ["Members", "Preferences", "Goals", "Constraints"]
      },
      {
        "id": "sources",
        "name": "Sources and audit",
        "job": "Source snapshots, audit events, template health and citation registry.",
        "collections": ["source_record", "audit_event"],
        "views": ["Latest sources", "Needs repair", "Undo window", "Template QA"]
      }
    ],
    "relation_views": [
      "Recipe uses ingredient and food item",
      "Meal plan plans recipe and creates shopping demand",
      "Shopping demand explains shopping item",
      "Purchase line fulfills shopping item and creates inventory lot",
      "Inventory movement moves lot and can be caused by meal log",
      "Nutrition observation describes meal log using nutrition profile",
      "Source record supports every citable record"
    ],
    "buttons": [
      {
        "name": "Plan dinner from pantry",
        "page": "Food",
        "action": "Create meal plan draft from use-first kitchen items"
      },
      {
        "name": "Add receipt",
        "page": "Purchases",
        "action": "Create purchase, purchase lines, unmatched review rows and lot candidates"
      },
      {
        "name": "Log cooked",
        "page": "Meal page",
        "action": "Create meal log and inventory movement candidates"
      },
      {
        "name": "Build shopping list",
        "page": "Shopping",
        "action": "Create shopping demands from planned meals and missing ingredients"
      }
    ]
  },
  "sheets": {
    "workbook_name": "LifeOS 2026 Food Workbook",
    "tabs": [
      {
        "name": "Home",
        "job": "Readable overview and setup checklist.",
        "columns": ["section", "status", "next_action", "link"]
      },
      {
        "name": "Records",
        "job": "Canonical import/export table.",
        "collections": ["*"],
        "columns": ["id", "domain", "collection", "title", "status", "meta", "body", "food_detail_json", "relations_json", "source_provider", "source_external_id", "source_url", "updated_at", "archived_at"]
      },
      {
        "name": "Relations",
        "job": "Edge list for every relation.",
        "columns": ["from_id", "name", "target_id", "from_collection", "target_collection", "source_id"]
      },
      {
        "name": "Kitchen",
        "job": "Food items, products, inventory, lots and movements.",
        "collections": ["food_item", "product", "inventory", "inventory_lot", "inventory_movement", "ingredient"],
        "columns": ["id", "collection", "title", "state", "quantity", "unit", "location", "best_by", "product_id", "lot_id", "movement_type", "reason", "food_detail_json"]
      },
      {
        "name": "Recipes",
        "job": "Recipes, revisions, steps, tools and nutrition profile links.",
        "collections": ["recipe", "recipe_revision", "recipe_step", "recipe_tool", "nutrition_profile"],
        "columns": ["id", "collection", "title", "servings", "prep_minutes", "cook_minutes", "step_order", "ingredient_state", "nutrition_profile_id", "food_detail_json"]
      },
      {
        "name": "Meals",
        "job": "Plans, templates, logs, consumption and observations.",
        "collections": ["meal_template", "meal_plan", "meal_log", "meal_consumption", "nutrition_observation"],
        "columns": ["id", "collection", "title", "date", "meal_slot", "status", "recipe_id", "member_id", "portion", "health_ref", "food_detail_json"]
      },
      {
        "name": "Shopping",
        "job": "Shopping lists, items, demand reasons and stores.",
        "collections": ["shopping_list", "shopping_item", "shopping_demand", "store"],
        "columns": ["id", "collection", "title", "state", "store", "aisle", "requested_qty", "purchased_qty", "demand_reason", "from_plan_id", "food_detail_json"]
      },
      {
        "name": "Purchases",
        "job": "Receipts, purchase lines, prices, returns and attachments.",
        "collections": ["purchase", "purchase_line", "attachment"],
        "columns": ["id", "collection", "merchant", "purchased_at", "line_title", "qty", "unit_price", "subtotal", "tax", "discount", "total", "created_inventory_lot_id", "attachment_url", "food_detail_json"]
      },
      {
        "name": "Household",
        "job": "Household, members, preferences and nutrition goals.",
        "collections": ["household", "member", "preference", "nutrition_goal"],
        "columns": ["id", "collection", "title", "member", "preference_type", "value", "goal_type", "target", "food_detail_json"]
      },
      {
        "name": "Sources",
        "job": "Source snapshots, audit events, sync receipts and citation handles.",
        "collections": ["source_record", "audit_event"],
        "columns": ["id", "collection", "provider", "external_id", "url", "version", "content_hash", "observed_at", "event_type", "actor", "undo_until"]
      },
      {
        "name": "Schema",
        "job": "Human-readable collection registry and validation notes.",
        "collections": ["*"],
        "columns": ["collection", "surface", "required", "relations", "notion_database", "sheets_tab", "notes"]
      }
    ],
    "protected_columns": ["id", "domain", "collection", "source_provider", "source_external_id", "content_hash"],
    "formula_policy": "User formulas and extra columns are preserved; canonical writes update only known columns.",
    "round_trip_policy": "All rows must preserve stable id, collection, food_detail_json, relations_json and source snapshot fields."
  },
  "collection_coverage": {
    "household": { "notion": ["Household"], "sheets": ["Household"] },
    "member": { "notion": ["Household"], "sheets": ["Household"] },
    "food_item": { "notion": ["Kitchen"], "sheets": ["Kitchen"] },
    "product": { "notion": ["Kitchen"], "sheets": ["Kitchen"] },
    "inventory": { "notion": ["Kitchen"], "sheets": ["Kitchen"] },
    "inventory_lot": { "notion": ["Kitchen"], "sheets": ["Kitchen"] },
    "inventory_movement": { "notion": ["Kitchen", "Purchases"], "sheets": ["Kitchen"] },
    "ingredient": { "notion": ["Kitchen"], "sheets": ["Kitchen"] },
    "recipe": { "notion": ["Recipes"], "sheets": ["Recipes"] },
    "recipe_revision": { "notion": ["Recipes"], "sheets": ["Recipes"] },
    "recipe_step": { "notion": ["Recipes"], "sheets": ["Recipes"] },
    "recipe_tool": { "notion": ["Recipes"], "sheets": ["Recipes"] },
    "meal_template": { "notion": ["Meals"], "sheets": ["Meals"] },
    "meal_plan": { "notion": ["Meals"], "sheets": ["Meals"] },
    "meal_log": { "notion": ["Meals"], "sheets": ["Meals"] },
    "meal_consumption": { "notion": ["Meals"], "sheets": ["Meals"] },
    "shopping_list": { "notion": ["Shopping"], "sheets": ["Shopping"] },
    "shopping_item": { "notion": ["Shopping"], "sheets": ["Shopping"] },
    "shopping_demand": { "notion": ["Shopping"], "sheets": ["Shopping"] },
    "purchase": { "notion": ["Purchases"], "sheets": ["Purchases"] },
    "purchase_line": { "notion": ["Kitchen", "Shopping", "Purchases"], "sheets": ["Purchases"] },
    "store": { "notion": ["Shopping"], "sheets": ["Shopping"] },
    "preference": { "notion": ["Household"], "sheets": ["Household"] },
    "nutrition_goal": { "notion": ["Household"], "sheets": ["Household"] },
    "nutrition_profile": { "notion": ["Recipes"], "sheets": ["Recipes"] },
    "nutrition_observation": { "notion": ["Meals"], "sheets": ["Meals"] },
    "attachment": { "notion": ["Purchases"], "sheets": ["Purchases"] },
    "audit_event": { "notion": ["Sources and audit"], "sheets": ["Sources"] },
    "source_record": { "notion": ["Sources and audit"], "sheets": ["Sources"] }
  },
  "sync_contract": {
    "webhooks_required": false,
    "hosted_server_required": false,
    "pull_supported": true,
    "manual_refresh_supported": true,
    "provider_undo_required": true,
    "unsupported_provider_fields_preserved": true,
    "source_snapshots_required": true
  }
}
