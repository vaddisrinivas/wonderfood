{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LifeOS data-plane template v1",
  "type": "object",
  "required": ["schema_version", "id", "title", "notion", "sheets", "collection_coverage", "sync_contract"],
  "properties": {
    "schema_version": { "const": "lifeos.data_plane_template.v1" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": { "type": "string" },
    "principles": { "type": "array", "items": { "type": "string" } },
    "authority_modes": { "type": "array", "items": { "type": "string" } },
    "notion": {
      "type": "object",
      "required": ["template_name", "max_navigation_depth", "home_page", "pages", "databases"],
      "properties": {
        "template_name": { "type": "string" },
        "max_navigation_depth": { "type": "integer", "minimum": 1, "maximum": 3 },
        "home_page": { "type": "object" },
        "pages": { "type": "array", "items": { "type": "object" } },
        "databases": { "type": "array", "items": { "type": "object" } },
        "relation_views": { "type": "array", "items": { "type": "string" } },
        "buttons": { "type": "array", "items": { "type": "object" } }
      }
    },
    "sheets": {
      "type": "object",
      "required": ["workbook_name", "tabs"],
      "properties": {
        "workbook_name": { "type": "string" },
        "tabs": { "type": "array", "items": { "type": "object" } },
        "protected_columns": { "type": "array", "items": { "type": "string" } },
        "formula_policy": { "type": "string" },
        "round_trip_policy": { "type": "string" }
      }
    },
    "collection_coverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["notion", "sheets"],
        "properties": {
          "notion": { "type": "array", "items": { "type": "string" } },
          "sheets": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "sync_contract": {
      "type": "object",
      "required": ["webhooks_required", "hosted_server_required", "pull_supported", "manual_refresh_supported", "provider_undo_required", "unsupported_provider_fields_preserved", "source_snapshots_required"],
      "properties": {
        "webhooks_required": { "type": "boolean" },
        "hosted_server_required": { "type": "boolean" },
        "pull_supported": { "type": "boolean" },
        "manual_refresh_supported": { "type": "boolean" },
        "provider_undo_required": { "type": "boolean" },
        "unsupported_provider_fields_preserved": { "type": "boolean" },
        "source_snapshots_required": { "type": "boolean" }
      }
    }
  }
}
